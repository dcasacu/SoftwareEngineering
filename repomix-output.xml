                                isLast: entry.key == activeQueue.length - 1,
                              );
                            }),
                        ],
                      ),
                    ),
                  ),
                  const SizedBox(height: 16),
                  if (shop.isOpen) ...[
                    if (myEntry != null)
                      OutlinedButton(
                        onPressed: () async {
                          final shopName = shop.name;
                          await context.read<QueueProvider>().leaveQueue(widget.shopId, auth.userId ?? '');
